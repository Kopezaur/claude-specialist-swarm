# Claude Code local settings — contains the API key, never commit
.claude/settings.local.json

# Microsoft Office lock files (created while a doc is open)
~$*

# Claude Code per-machine state — regenerated on every run
.claude/audit.log
.claude/scheduled_tasks.lock

# Python virtualenv
.venv/

# Local run logs from run_deal_desk.py | tee
outputs-*.log

# Python bytecode
__pycache__/
*.pyc

# Eval results (regenerated by evals/eval_specialists.py)
evals/results/
